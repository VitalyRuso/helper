# Development defaults only. Change credentials outside local development.
APP_NAME=Spain Helper AI
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
VITE_API_URL=http://localhost:8000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/spain_helper

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=spain_helper_main

DOCS_DIR=../../docs
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_FALLBACK=disabled

ACCESS_KEYS=demo-access-key
GUEST_QUESTION_LIMIT=3

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-use

LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
